# Apollo IAM Engine — environment variables
# Copie para .env e ajuste os valores

SECRET_KEY=change-me-super-secret-key-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=sqlite:///./data/apollo_iam.db
LOG_LEVEL=INFO
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
APP_NAME=Apollo IAM Engine
APP_VERSION=1.0.0
CORS_ORIGINS=*

# ── mTLS ──────────────────────────────────────────────────────
# true  → HTTPS/mTLS nas portas 8443/8444
# false → HTTP nas portas 8000/8080 (desenvolvimento sem TLS)
MTLS_ENABLED=true
MTLS_CERTS_DIR=certs
MTLS_API_PORT=8443
MTLS_WEBAPP_PORT=8444
# required | optional | disabled
MTLS_CLIENT_AUTH=optional
